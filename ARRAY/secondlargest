def second_largest(arr):
    if len(arr)<2:
        return -1
    first = second = -1 
    for num in arr:
        if num >first:
            second =first 
            first = num 
        elif num >second and num != first:
            second = num 
            return second 
        if second == first :
            return -1

arr = [12, 35, 1, 10, 34, 1]
print(second_largest(arr))
